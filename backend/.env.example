# Comma-separated list of allowed frontend origins
# Local development:
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production (set this in Render environment variables):
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Port — Render sets this automatically; only needed if running locally on a non-default port
# PORT=8000
